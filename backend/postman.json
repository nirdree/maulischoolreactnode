          "request": { "method": "PATCH", "url": "{{baseUrl}}/api/classrooms/{{classroomId}}/toggle" }
        },
        {
          "name": "Delete Classroom",
          "request": { "method": "DELETE", "url": "{{baseUrl}}/api/classrooms/{{classroomId}}" }
