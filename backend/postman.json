              "raw": "{\n  \"className\": \"4\",\n  \"section\": \"A\",\n  \"displayName\": \"Class 4-A\",\n  \"monthlyFees\": 4500,\n  \"order\": 5,\n  \"capacity\": 40,\n  \"isActive\": true,\n  \"academicYear\": \"{{academicYearId}}\"\n}"
