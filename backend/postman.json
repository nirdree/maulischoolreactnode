{
  "info": {
    "name": "School Management System — Full API",
    "description": "Complete Postman collection for School Management System backend.\n\n**Setup:**\n1. Run seed.js to populate the DB.\n2. Call POST /api/auth/login → copy the token.\n3. In this collection's Variables tab set `baseUrl` and `token`.\n4. All protected requests use Bearer {{token}} automatically.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000", "type": "string" },
    { "key": "token",   "value": "PASTE_JWT_HERE",        "type": "string" },
    { "key": "academicYearId",  "value": "", "type": "string" },
    { "key": "classroomId",     "value": "", "type": "string" },
    { "key": "studentId",       "value": "", "type": "string" },
    { "key": "employeeId",      "value": "", "type": "string" },
    { "key": "subjectId",       "value": "", "type": "string" },
    { "key": "examId",          "value": "", "type": "string" },
    { "key": "feeId",           "value": "", "type": "string" },
    { "key": "payrollId",       "value": "", "type": "string" },
    { "key": "leaveId",         "value": "", "type": "string" },
    { "key": "homeworkId",      "value": "", "type": "string" },
    { "key": "noticeId",        "value": "", "type": "string" },
    { "key": "enquiryId",       "value": "", "type": "string" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "item": [

    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "Register User",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"New Admin\",\n  \"email\": \"newadmin@school.com\",\n  \"password\": \"Admin@123\",\n  \"role\": \"admin\"\n}"
            }
          }
        },
        {
          "name": "Login — Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data.token) {",
                  "  pm.collectionVariables.set('token', json.data.token);",
                  "  console.log('Token saved:', json.data.token.substring(0,30)+'...');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@school.com\",\n  \"password\": \"Admin@123\"\n}"
            }
          }
        },
        {
          "name": "Login — Principal",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"principal@school.com\",\n  \"password\": \"Principal@123\"\n}"
            }
          }
        },
        {
          "name": "Login — Teacher",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"priya.patel@school.com\",\n  \"password\": \"Teacher@123\"\n}"
            }
          }
        },
        {
          "name": "Login — Parent",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"anil.gupta@gmail.com\",\n  \"password\": \"Parent@123\"\n}"
            }
          }
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/auth/me"
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/change-password",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currentPassword\": \"Admin@123\",\n  \"newPassword\": \"Admin@456\"\n}"
            }
          }
        }
      ]
    },

    {
      "name": "📅 Academic Years",
      "item": [
        {
          "name": "Get All Academic Years",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/academic-years" }
        },
        {
          "name": "Get Current Academic Year",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/academic-years/current" }
        },
        {
          "name": "Get Academic Year by ID",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/academic-years/{{academicYearId}}" }
        },
        {
          "name": "Create Academic Year",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/academic-years",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"2025-2026\",\n  \"startDate\": \"2025-04-01\",\n  \"endDate\": \"2026-03-31\",\n  \"isCurrent\": false\n}"
            }
          }
        },
        {
          "name": "Update Academic Year",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/academic-years/{{academicYearId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"2025-2026\",\n  \"startDate\": \"2025-04-01\",\n  \"endDate\": \"2026-03-31\"\n}"
            }
          }
        },
        {
          "name": "Set Current Academic Year",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/api/academic-years/{{academicYearId}}/set-current"
          }
        },
        {
          "name": "Delete Academic Year",
          "request": { "method": "DELETE", "url": "{{baseUrl}}/api/academic-years/{{academicYearId}}" }
        }
      ]
    },

    {
      "name": "🏫 Classrooms",
      "item": [
